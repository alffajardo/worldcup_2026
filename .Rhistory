reorder(picks$`How far will Mexico advance in the tournament?`,
order = c("Round of 16","Quarter-finals","Semi-Finals") )                                                        )
reorder(picks$`How far will Mexico advance in the tournament?`,
X = c("Round of 16","Quarter-finals","Semi-Finals") )                                                        )
