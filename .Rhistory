select(PSCID,amy_status_bl) %>%
full_join(tau) %>%
filter( amy_status_bl == "AB-",
Visit_label_PET == "ses-01") %>%
select(thresh_meta_roi_bilat) %>%
summarize ( mean = mean(thresh_meta_roi_bilat,na.rm = T),
sd = sd(thresh_meta_roi_bilat,na.rm = T),
thr = mean + (2 *sd ))  %>%
pull(thr)
tau_status <- tau %>%
filter(Visit_label_PET == "ses-01") %>%
mutate(tau_status_bl = if_else(thresh_meta_roi_bilat < tau_theshold,"T-","T+")
) %>%
select(PSCID, tau_status_bl)
pet2 <- centiloids %>%
full_join(amy_status) %>%
full_join(tau_status) %>%
full_join(centiloids) %>%
full_join(pet)
pet <- pet2
pet <- pet %>%
group_by(PSCID, Tracer_PET) %>%
mutate(n_timepoints = n() %>%
as.character %>%
factor()) %>%
ungroup
numeric_variables_pet <- pet %>%
keep(is.numeric) %>%
names()
numeric_variables_pet <- numeric_variables_pet[numeric_variables_pet != "age_PET"]
pet <- pet %>%
filter(Visit_label_PET != "ses-03",
age_group =="Older")
pet_splitted <- pet %>%
filter(n_timepoints != "1") %>%
group_by(Tracer_PET,Visit_label_PET) %>% # grouping varialbes
group_split() # generate de list
# this is the number of years between BL and FU
amy_years <- difftime(pet_splitted[[2]]$PET_scan_dates,
pet_splitted[[1]]$PET_scan_dates) %>%
time_length("years") %>%
bind_cols(pet_splitted[[1]]$PSCID, .) %>%
set_names(c("PSCID","amy_years"))
## now lets calculate the centiloid rate of cahnte
CL_RC <- amy_years %>%
full_join(centiloids) %>%
filter(Visit_label_PET != "ses-03") %>%
pivot_wider(values_from = Centiloid,names_from = Visit_label_PET) %>%
mutate(CL_RC = (`ses-02` - `ses-01`) / amy_years) %>%
select(PSCID, CL_RC)
amy_RC_tmp <- (pet_splitted[[2]][numeric_variables_pet] - pet_splitted[[1]][numeric_variables_pet]) / amy_years$amy_years
# create the definitive RC amyloid dataset
amy_RC <- pet_splitted[[1]]%>%
select(PSCID,Tracer_PET,
amy_status_bl,age_PET,Sex,age_group,tau_status_bl) %>%
left_join(., CL_RC) %>%
bind_cols(amy_RC_tmp) %>%
select(-Centiloid)
# rm the amy tmp
rm(amy_RC_tmp)
# calculate the tau years
tau_years <- difftime(pet_splitted[[4]]$PET_scan_dates,
pet_splitted[[3]]$PET_scan_dates) %>%
time_length("years") %>%
bind_cols(pet_splitted[[3]]$PSCID, .) %>%
set_names(c("PSCID","tau_years"))
tau_RC_tmp <- (pet_splitted[[4]][numeric_variables_pet] - pet_splitted[[3]][numeric_variables_pet]) / tau_years$tau_years
# Final dataset for the annual rate of change
# create the definitive RC tau dataset
tau_RC <- pet_splitted[[3]]%>%
select(PSCID,Tracer_PET,
amy_status_bl,Sex,age_PET,age_group,tau_status_bl) %>%
left_join(CL_RC) %>%
bind_cols(tau_RC_tmp)  %>%
select(-Centiloid)
rm(tau_RC_tmp)
rm(amy_RC_tmp)
amy_RC <- amy_RC %>%
add_column(AB_accumulator = ifelse(.$CL_RC >= 2.19 |  .$amy_status_bl =="AB+", 1, 0), .before = 6)
tau_acc_thr <- 0.02208
tau_RC <- tau_RC %>%
add_column(tau_accumulator = ifelse(.$thresh_meta_roi_bilat >= tau_acc_thr | .$tau_status_bl == "T+", 2, 0), .before = 6)
group <- amy_RC %>%
select(PSCID, AB_accumulator) %>%
full_join(select(tau_RC,PSCID,tau_accumulator)) %>%
mutate(Group = AB_accumulator+ tau_accumulator)
group$AB_accumulator <- factor(group$AB_accumulator,labels = c("Non-Acc", "AB-Acc" ))
group$tau_accumulator <- factor(group$tau_accumulator,labels = c("Non-Acc", "Tau-Acc"))
group$Group <-  factor(group$Group,
labels = c("Non-Acc","AB-only-Acc","Tau-only-Acc","AB & Tau-acc"))
amy_RC <- amy_RC %>%
select(-AB_accumulator) %>%
right_join(group,.)
tau_RC <-  tau_RC %>%
select(-tau_accumulator) %>%
right_join(group,.)
pet_RC <- bind_rows(amy_RC,tau_RC) %>%
arrange(PSCID)
contingency_table <- pet_RC %>%
filter(!duplicated(PSCID)) %>%
select(AB_accumulator,tau_accumulator) %>%
table()
contingency_table
pet <- group %>%
full_join(pet)
