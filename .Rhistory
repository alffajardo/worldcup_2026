str_replace_all("ctx-rh-","rh_") %>%
str_replace_all("ctx-lh-","lh_")
names(amy) <- names(tau)
pet <- bind_rows(amy,tau) %>%
filter(PSCID !="MTL0488")
preventad_info <- read.csv("data_release_8.1/PREVENT-AD_internal_n387__AD8.csv")
demographics <- read.csv("data_release_8.1/PREVENT-AD_internal_n387__Demographics.csv")
preventad_info <- full_join(preventad_info,demographics)
preventad_info$Sex <- factor(preventad_info$Sex)
age_pet<- select(preventad_info,PSCID,
Date_taken,Candidate_Age,Sex) %>%
right_join(., select(pet,PSCID,Visit_label_PET, PET_scan_dates)) %>%
filter(!duplicated(PSCID)) %>%
mutate(diffdates = difftime(PET_scan_dates,Date_taken) %>%
time_length('month'),
age_PET = (Candidate_Age + diffdates)/12) %>%
select(PSCID,Sex,age_PET)
pet <- full_join(age_pet,pet)
centiloids <- read.csv("pre_DS2026/PAD_PET_NAV_space-tpl_Jan2026.csv") %>%
mutate(Centiloid = WhlCbl_centiloid,
age_group = if_else(PSCID %in% young_ids,"Young","Older")) %>%
select(PSCID,Visit_label_PET,Centiloid,age_group)
amy_status <- centiloids %>%
filter(Visit_label_PET == "ses-01")  %>%
mutate(amy_status_bl = if_else(Centiloid >= 20,  "AB+","AB-")) %>%
select(PSCID, amy_status_bl)
Suvr_thr_amy_status <- CL2gmsuvr(20)
print(Suvr_thr_amy_status)
tau_theshold <- amy_status %>%
select(PSCID,amy_status_bl) %>%
full_join(tau) %>%
filter( amy_status_bl == "AB-",
Visit_label_PET == "ses-01") %>%
select(thresh_meta_roi_bilat) %>%
summarize ( mean = mean(thresh_meta_roi_bilat,na.rm = T),
sd = sd(thresh_meta_roi_bilat,na.rm = T),
thr = mean + (2 *sd ))  %>%
pull(thr)
tau_status <- tau %>%
filter(Visit_label_PET == "ses-01") %>%
mutate(tau_status_bl = if_else(thresh_meta_roi_bilat < tau_theshold,"T-","T+")
) %>%
select(PSCID, tau_status_bl)
pet2 <- centiloids %>%
full_join(amy_status) %>%
full_join(tau_status) %>%
full_join(centiloids) %>%
full_join(pet)
pet <- pet2
pet <- pet %>%
group_by(PSCID, Tracer_PET) %>%
mutate(n_timepoints = n() %>%
as.character %>%
factor()) %>%
ungroup
numeric_variables_pet <- pet %>%
keep(is.numeric) %>%
names()
numeric_variables_pet <- numeric_variables_pet[numeric_variables_pet != "age_PET"]
pet <- pet %>%
filter(Visit_label_PET != "ses-03",
age_group =="Older")
pet_splitted <- pet %>%
filter(n_timepoints != "1") %>%
group_by(Tracer_PET,Visit_label_PET) %>% # grouping varialbes
group_split() # generate de list
# this is the number of years between BL and FU
amy_years <- difftime(pet_splitted[[2]]$PET_scan_dates,
pet_splitted[[1]]$PET_scan_dates) %>%
time_length("years") %>%
bind_cols(pet_splitted[[1]]$PSCID, .) %>%
set_names(c("PSCID","amy_years"))
## now lets calculate the centiloid rate of cahnte
CL_RC <- amy_years %>%
full_join(centiloids) %>%
filter(Visit_label_PET != "ses-03") %>%
pivot_wider(values_from = Centiloid,names_from = Visit_label_PET) %>%
mutate(CL_RC = (`ses-02` - `ses-01`) / amy_years) %>%
select(PSCID, CL_RC)
amy_RC_tmp <- (pet_splitted[[2]][numeric_variables_pet] - pet_splitted[[1]][numeric_variables_pet]) / amy_years$amy_years
# create the definitive RC amyloid dataset
amy_RC <- pet_splitted[[1]]%>%
select(PSCID,Tracer_PET,
amy_status_bl,age_PET,Sex,age_group,tau_status_bl) %>%
left_join(., CL_RC) %>%
bind_cols(amy_RC_tmp) %>%
select(-Centiloid)
# rm the amy tmp
rm(amy_RC_tmp)
# calculate the tau years
tau_years <- difftime(pet_splitted[[4]]$PET_scan_dates,
pet_splitted[[3]]$PET_scan_dates) %>%
time_length("years") %>%
bind_cols(pet_splitted[[3]]$PSCID, .) %>%
set_names(c("PSCID","tau_years"))
tau_RC_tmp <- (pet_splitted[[4]][numeric_variables_pet] - pet_splitted[[3]][numeric_variables_pet]) / tau_years$tau_years
# Final dataset for the annual rate of change
# create the definitive RC tau dataset
tau_RC <- pet_splitted[[3]]%>%
select(PSCID,Tracer_PET,
amy_status_bl,Sex,age_PET,age_group,tau_status_bl) %>%
left_join(CL_RC) %>%
bind_cols(tau_RC_tmp)  %>%
select(-Centiloid)
rm(tau_RC_tmp)
rm(amy_RC_tmp)
getwd()
rm (list = ls()
library(googledrive)
library(googlesheets4)
library(corrplot)
library(viridis)
library(dplyr)
library(readr)
library(stringr)
library(tidyr)
library(ggplot2)
options(gargle_oauth_email = TRUE)
drive_auth(email = TRUE)
picks_id <- drive_find(type = "spreadsheet",pattern = "Wc2026: KO Stage 32_a ",
n_max = 1)$id
picks2_id <-  drive_find(type = "spreadsheet",pattern = "KO Stage 32_b")
picks <- read_sheet(picks_id)
picks2 <- read_sheet(picks2_id)
picks$Participant_ID <- as.character( as.character(picks$Participant_ID)) %>%
str_pad(pad = "0", side = "left", width = 3)
picks2$Participant_ID <- as.character( as.character(picks2$Participant_ID)) %>%
str_pad(pad = "0", side = "left", width = 3)
picks2 <- select(picks2,4:ncol(picks2))
picks <- full_join(picks,picks2)
bets <- picks[,c(3,4,5:ncol(picks))] %>%
tibble() %>%
arrange(Participant_ID) %>%
select(!ends_with("Score"))
scores_prediction <- picks %>%
arrange(Participant_ID) %>%
select(Participant_ID,ends_with("Score"),-Score)
write.table(bets,"K16_picks.csv",sep=",",
quote = F,
row.names =F )
write.table(scores_prediction,"K16_predicted_scores.csv",sep=",",
quote = F,
row.names =F )
bets2 <- pivot_longer(bets,3:ncol(bets),
names_to = "Match",
values_to = "Bet")
bets2_summary <- bets2 %>%
group_by(Match) %>%
count(Bet,na.rm = T) %>%
ungroup() %>%
arrange(desc(n)) %>%
filter(complete.cases(.))
bets2_summary$Bet <- factor(bets2_summary$Bet,levels = bets2_summary$Bet)
bets2_summary$Match <- factor(bets2_summary$Match)
plot1 <- ggplot(bets2_summary,aes(x=Match,y = n,fill = Bet))+
geom_bar(stat = "identity",width = 0.8)+
ylim(c(0,20))+
ggtitle("Knock Out stage: Round of 32 predictions")+
theme_minimal()+
theme(axis.text.x = element_text(face = 2,angle = 60,
vjust = T,hjust = T))+
xlab(" ")+
ylab("Frequency")
ggsave("picks_K16.png",plot = plot1,units = "px",width = 1200,height = 1200,
path = "media",dpi = 200,bg =  "white")
