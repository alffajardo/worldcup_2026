x <- imager::load.image(paste(local,".png",sep=''))
y <- load.image(paste(visitor,".png",sep=''))
png(filename = output,
height = 350,width = 800,res = 170,units = "px")
par(mar = c(0.5,0.5,2,0.5),mfrow = c(1,2),
bg = "gray97")
plot(x,axes = F,main = local,
cex.main = 30)
plot(y,axes = F,main = visitor)
dev.off()
rm(i)
